{
    "project": "ContainerKit",
    "license": "license-header.txt",
    "paths": [
        {
            "glob": "src/**/*.js",
            "type": "prepend"
        },
        {
            "glob": "src/**/*.ts",
            "type": "prepend"
        },
        {
            "glob": "src/**/*.svelte",
            "type": "prepend"
        },
        {
            "glob": "scripts/**/*.js",
            "type": "prepend"
        },
        {
            "glob": "scripts/**/*.ts",
            "type": "prepend"
        },
        {
            "glob": "scripts/**/*.sh",
            "type": "prepend"
        },
        {
            "glob": "src-tauri/**/*.rs",
            "type": "prepend"
        }
    ],
    "exclude": [
        "node_modules/**",
        "dist/**",
        "src-tauri/target/**",
        "src-tauri/binaries/**",
        "src-tauri/**/*.lock",
        "src-tauri/migrations/**"
    ]
}
